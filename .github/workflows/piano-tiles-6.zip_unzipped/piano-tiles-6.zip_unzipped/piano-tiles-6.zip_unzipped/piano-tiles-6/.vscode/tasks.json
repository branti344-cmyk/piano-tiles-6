{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "npm",
      "script": "dev",
      "label": "npm: dev",
      "detail": "Start Vite dev server",
      "isBackground": true,
      "problemMatcher": {
        "pattern": {
          "regexp": "^(?:\\s+✗\\s+)(.*)",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": "^.*VITE.*dev server running",
          "endsPattern": "^.*Local:.*http"
        }
      }
    },
    {
      "type": "npm",
      "script": "build",
      "label": "npm: build",
      "detail": "Build for production"
    },
    {
      "type": "npm",
      "script": "deploy",
      "label": "npm: deploy",
      "detail": "Deploy to GitHub Pages"
    }
  ]
}
